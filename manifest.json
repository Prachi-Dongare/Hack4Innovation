{
  "manifest_version": 3,
  "name": "Scam Shield",
  "version": "1.0",

  "permissions": ["activeTab"],

  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}