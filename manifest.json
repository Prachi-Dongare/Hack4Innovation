{
  "manifest_version": 3,
  "name": "Scam Protector MVP",
  "version": "1.0",
  "description": "Real-time scam detection extension",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ]
}